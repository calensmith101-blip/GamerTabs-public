# GamerTabs commercial SaaS environment template
# Copy these names into Vercel Project Settings → Environment Variables.
# Do not commit real .env files. Rotate any key that was ever pasted into Git or a shared zip.

# Frontend-safe values only
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY
VITE_APP_URL=https://gamertabs.cjsapplabs.xyz

# Server-only values. Never expose these in frontend code.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET_GAMERTABS=YOUR_GAMERTABS_WEBHOOK_SIGNING_SECRET
STRIPE_PRICE_ID_GAMERTABS=price_YOUR_GAMERTABS_SUBSCRIPTION_PRICE_ID
APP_URL=https://gamertabs.cjsapplabs.xyz
